# Make a copy of this file, name that copy '.env' and replace the follow variables with your own canvas token and canvas url in the copy.
# The url will be different for each school, so be sure it is correct for your institution.
#
# For example, if your a student at BSU, the correct canvas url would be 
# 'https://boisestatecanvas.instructure.com' 
# NOT 
# 'https://canvas.instructure.com'
#
CANVAS_TOKEN=YOUR_TOKEN_HERE
CANVAS_URL=YOUR_CANVAS_URL_HERE
